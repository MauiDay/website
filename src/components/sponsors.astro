---
import loadConfig from "../configLoader";
import type { Sponsor } from "../types";

const config = Astro.props.config ?? await loadConfig();
const sponsors: Sponsor[] = config.sponsors ?? [];
const supporters: Sponsor[] = config.supporters ?? [];
const communityPartners: Sponsor[] = config.communityPartners ?? [];
---

<section id="sponsors" class="bg-white py-24 px-0">
  <div class="container max-w-4xl mx-auto px-4 text-center">
    <p class="text-brand-extra font-bold mb-4 text-xl font-header uppercase">
      We couldn't do it without you
    </p>
    <h2 class="text-brand-dark text-4xl md:text-4xl uppercase font-header font-bold mb-4">
      Our Sponsors
    </h2>
    <p class="text-brand-dark text-base text-md mb-8">
      Our awesome sponsors are what make this event possible. They help us to
      keep the event free and accessible to everyone. Please take a moment to
      check them out and show them some love.
    </p>

    <!-- Sponsors -->
    <div class="grid grid-cols-1 sm:grid-cols-2 gap-6 justify-center place-items-center">
      {sponsors.map((sponsor) => (
        <a
          href={sponsor.url}
          target="_blank"
          rel="noopener noreferrer"
          class="flex flex-col items-center p-4 transition-transform opacity-70 transform hover:scale-105 hover:opacity-100 w-full"
        >
          <img
            src={`/images/sponsors/${sponsor.logo}.png`}
            alt={sponsor.name}
            class="w-full object-contain mb-4"
            loading="lazy"
          />
        </a>
      ))}
    </div>

    <div class="text-center mt-12">
      <a
        href="mailto:hello@mauiday.net?subject=We're%20interested%20in%20sponsoring"
        class="btn-gradient px-8 py-4 rounded-full font-bold text-white shadow-lg shadow-pink-500/30 hover:shadow-pink-500/50 transform hover:-translate-y-0.5 transition-all duration-300 inline-flex items-center justify-center gap-2"
      >
        Interested in sponsoring? Get in touch
      </a>
    </div>

    <!-- Supporters -->
    {supporters.length > 0 && (
      <div class="mt-16">
        <h3 class="text-brand-dark text-2xl md:text-3xl uppercase font-header font-bold mb-4">
          Our Supporters
        </h3>
        <p class="text-brand-dark text-base text-md mb-8">
          Our supporters help make the day even better. They provide prizes,
          power the platforms we rely on, and back our speakers along the way.
        </p>
        <div class="flex flex-wrap justify-center gap-6">
          {supporters.map((supporter) => (
            <a
              href={supporter.url}
              target="_blank"
              rel="noopener noreferrer"
              class="flex flex-col items-center p-4 transition-transform opacity-70 transform hover:scale-105 hover:opacity-100 w-full sm:w-[calc(33.333%-1rem)]"
            >
              <img
                src={`/images/sponsors/${supporter.logo}.png`}
                alt={supporter.name}
                class="w-4/5 sm:w-full md:w-3/4 object-contain mb-4"
                loading="lazy"
              />
            </a>
          ))}
        </div>
      </div>
    )}

    <!-- Partners -->
    {communityPartners.length > 0 && (
      <div class="mt-16">
        <h3 class="text-brand-dark text-2xl md:text-3xl uppercase font-header font-bold mb-4">
          Our Partners
        </h3>
        <p class="text-brand-dark text-base text-md mb-8">
          Our partners help make the day happen behind the scenes and spread
          the word in the local community. We're grateful for everything they do
          to bring people together.
        </p>
        <div class="flex flex-wrap justify-center gap-6">
          {communityPartners.map((partner) => (
            <a
              href={partner.url}
              target="_blank"
              rel="noopener noreferrer"
              class="flex flex-col items-center p-4 transition-transform opacity-70 transform hover:scale-105 hover:opacity-100 w-full sm:w-[calc(33.333%-1rem)]"
            >
              <img
                src={`/images/sponsors/${partner.logo}.png`}
                alt={partner.name}
                class="w-4/5 sm:w-full md:w-3/4 object-contain mb-4"
                loading="lazy"
              />
            </a>
          ))}
        </div>
      </div>
    )}
  </div>
</section>
