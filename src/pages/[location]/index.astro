---
import Layout from '../../layouts/Layout.astro';
import Hero from '../../components/hero.astro';
import About from '../../components/about.astro';
import Location from '../../components/location.astro';
import CFS from '../../components/cfs.astro';
import Sponsors from '../../components/sponsors.astro';
import Speakers from '../../components/speakers-js.astro';
import Schedule from '../../components/schedule-js.astro';
import Newsletter from '../../components/newsletter.astro';
import loadConfig from '../../configLoader';
import { eventLocations } from '../../data/eventLocations';

export async function getStaticPaths() {
return Promise.all(
eventLocations.map(async (event) => ({
params: { location: event.slug },
props: {
event,
config: await loadConfig(event.config),
},
}))
);
}

const { event, config } = Astro.props;
const basePath = `/${event.slug}`;
---

<Layout eventConfig={config} eventBasePath={basePath}>
<Hero config={config} basePath={basePath} />
<About />
{config.hasCfs ? ( <CFS config={config} /> ) : <></>}
{config.hasAnnouncedSpeakers ? ( <Speakers config={config} /> ) : <></>}
{config.hasAnnouncedSchedule ? ( <Schedule config={config} /> ) : <></>}
<Location config={config} />
<Sponsors config={config} />
<Newsletter />
</Layout>
