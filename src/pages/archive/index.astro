---
import Layout from "../../layouts/Layout.astro";
import { getArchiveEvents } from "../../data/archive";
import { fetchAlbums, getAlbumThumbUrls, getAlbumThumbnail } from "../../data/gallery";

const events = getArchiveEvents();
const albums = await fetchAlbums();

const eventsWithThumbs = events.map((event) => {
  const album = albums.find((a) => a.id === event.galleryAlbumId);
  const badgeImage = event.badgeImage ? `/images/editions/${event.badgeImage}` : '';
  let thumbnail = '/images/default.png';
  if (album) {
    const thumbUrls = getAlbumThumbUrls(album);
    thumbnail = getAlbumThumbnail(album, thumbUrls);
  }
  return { ...event, badgeImage, thumbnail };
});

const hasBadgeEvents = eventsWithThumbs.some((event) => event.badgeImage);
---

<Layout pageTitle="Archive | MAUI Day">
  <section class="bg-brand-dark py-40">
    <div class="container max-w-5xl mx-auto px-4 text-center">
      <p class="text-brand-extra font-bold mb-4 text-xl font-header uppercase">Looking Back</p>
      <h2 class="text-white text-4xl uppercase font-header font-bold mb-4">Event Archive</h2>
      <p class="text-white text-base text-md mb-12">
        Browse past MAUI Day and XamExpertDay events, or <a href="/history" class="text-brand-extra font-bold hover:underline">read the backstory</a>.
      </p>

      {hasBadgeEvents && (
        <div class="mb-12 rounded-3xl border border-white/10 bg-white/5 p-6 text-left">
          <div class="flex flex-col md:flex-row gap-5 md:items-center">
            <div class="size-14 shrink-0 rounded-2xl bg-brand-extra/20 text-brand-extra flex items-center justify-center">
              <i class="fa-solid fa-award text-2xl"></i>
            </div>
            <div>
              <p class="text-brand-extra font-bold mb-2 text-sm font-header uppercase tracking-wide">Collectible event badges</p>
              <h3 class="text-white text-2xl font-header font-bold mb-2">Not just artwork: these are physical badges too.</h3>
              <p class="text-brand-light/70 text-sm leading-relaxed">
                Badge-enabled MAUI Day editions have a matching physical badge attendees can wear on clothing,
                lanyards, bags, or wherever they collect conference memories. Each badge links back to the
                event archive so the collection also tells the story of where it came from.
              </p>
            </div>
          </div>
        </div>
      )}

      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-8 text-left">
        {eventsWithThumbs.map((event) => (
          <a href={`/archive/${event.id}`} class="group block">
            <div class="overflow-hidden rounded-3xl shadow-md aspect-[4/3] bg-brand-dark border border-white/10">
              {event.badgeImage ? (
                <div class="relative w-full h-full flex items-center justify-center bg-gradient-to-br from-brand-dark via-brand-dark to-brand-extra/40">
                  <div class="absolute inset-0 bg-[radial-gradient(circle_at_center,_rgba(201,60,173,0.25),_transparent_55%)]"></div>
                  <span class="absolute top-4 left-4 rounded-full border border-white/15 bg-white/10 px-3 py-1 text-xs font-bold uppercase tracking-wide text-white/80">
                    Physical badge
                  </span>
                  <img
                    src={event.badgeImage}
                    alt={`${event.title} badge`}
                    class="relative z-10 size-40 object-contain drop-shadow-2xl group-hover:scale-105 transition-transform duration-300"
                    loading="lazy"
                  />
                </div>
              ) : event.thumbnail !== '/images/default.png' ? (
                <img
                  src={event.thumbnail}
                  alt={event.title}
                  class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-300"
                  loading="lazy"
                />
              ) : (
                <div class="w-full h-full flex items-center justify-center text-gray-400">
                  <i class="fa-solid fa-calendar-days text-4xl"></i>
                </div>
              )}
            </div>
            <h3 class="mt-3 text-lg font-bold text-white font-header group-hover:text-brand-extra transition-colors">
              {event.title}
            </h3>
            <p class="text-sm text-brand-light/70">
              {new Date(event.date).toLocaleDateString("en-US", { year: "numeric", month: "long", day: "numeric" })}
              {event.location.name && ` · ${event.location.name}`}
            </p>
            <p class="text-xs text-brand-light/50 mt-1">
              {event.speakers.length > 0 && `${event.speakers.length} speakers`}
              {event.speakers.length > 0 && event.sessions.length > 0 && ' · '}
              {event.sessions.length > 0 && `${event.sessions.length} sessions`}
            </p>
          </a>
        ))}
      </div>
    </div>
  </section>
</Layout>
